# Обязательные переменные для запуска React-фронтенда
# При деплое на Railway или Vercel укажите URL вашего реального бэкенда.

# 1. URL к вашему FastAPI бэкенду (в Railway это будет Public Domain бэкенд сервера)
# Пример для локальной разработки:
VITE_API_URL=http://localhost:8000/api
# Пример для продакшена (Railway):
# VITE_API_URL=https://opus-backend-production.up.railway.app/api
