# Обязательные переменные для запуска Telegram-бота
# Пропишите их в Railway Variables для сервиса бота

# 1. Токен телеграм-бота (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# 2. Подключение к базе данных Supabase
# Бот использует только Service Key для прямой записи анкет в таблицу
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# 3. Railway Postgres для хранения фото
RAILWAY_DATABASE_URL=postgresql://user:password@host:5432/dbname

# 4. Необязательные переменные для ручной верификации
# Отдельный бот модератора будет получать новые анкеты с кнопками.
# Уведомления уйдут во все чаты, которые хотя бы раз нажали /start в verification bot.
VERIFICATION_BOT_TOKEN=your_verification_bot_token_here
