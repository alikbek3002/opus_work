# Обязательные переменные для запуска FastAPI бэкенда
# Эти переменные необходимо прописать в Variables в Railway

# 1. Ссылки и ключи базы данных (Supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
APP_URL=http://localhost:5173
CRON_SECRET=your_cron_secret_here
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=mailer@example.com
SMTP_FROM_NAME=Opus
SMTP_USE_TLS=true

# 2. Секретный ключ для подписи токенов авторизации (JWT)
# Сгенерируйте любую длинную случайную строку (например, через openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-for-opus

# 3. Настройка разрешенных доменов для запросов (CORS)
# Укажите через запятую адреса вашего фронтенда (Vercel/Railway).
# Для тестов можно оставить *, но в продакшене лучше указать конкретный домен.
# Пример: https://opus-web.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# 4. Настройки Finik Acquiring API
# Ваш API ключ (x-api-key)
FENIK_PAY_API_KEY=your_finik_api_key

# Корпоративный accountId в Finik (если не задан, используется FENIK_PAY_MERCHANT_ID как fallback)
FENIK_ACCOUNT_ID=your_finik_account_id
FENIK_PAY_MERCHANT_ID=legacy_fallback_account_id

# MCC и имя QR
FENIK_MERCHANT_CATEGORY_CODE=0742
FENIK_QR_NAME=Opus

# URL Finik API (prod и beta)
FENIK_API_BASE_URL=https://api.acquiring.averspay.kg
# FENIK_API_BASE_URL=https://beta.api.acquiring.averspay.kg

# URL вашего backend webhook (если пусто, собирается автоматически из текущего host)
FENIK_WEBHOOK_URL=

# Приватный ключ (для подписи исходящих запросов)
# Можно передать либо inline-значением, либо через путь к файлу.
FENIK_PRIVATE_KEY=
FENIK_PRIVATE_KEY_PATH=/app/keys/finik_private.pem

# Публичный ключ Finik (для проверки webhook подписи)
# Проверка включается, если FENIK_VERIFY_SIGNATURE=true
FENIK_PUBLIC_KEY=
FENIK_PUBLIC_KEY_PATH=/app/keys/finik_public.pem
FENIK_VERIFY_SIGNATURE=false

# Таймаут исходящих HTTP запросов в Finik (сек)
FENIK_REQUEST_TIMEOUT_SEC=20
